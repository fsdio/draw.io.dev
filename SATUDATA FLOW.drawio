        <mxCell id="UMBiTt1FIwDFNFkxnXiM-14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;HISTORY TIMELINE&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="-297" y="410" as="geometry" />
        </mxCell>
        <mxCell id="UMBiTt1FIwDFNFkxnXiM-16" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Kesimpulan&lt;/span&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="40" width="487" x="-1068" y="390" as="geometry" />
        </mxCell>
        <mxCell id="UMBiTt1FIwDFNFkxnXiM-18" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div style=&quot;text-align: justify;&quot;&gt;Impact Development&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Dari sisi SATUDATA&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Existing architecture SATUDATA sudah modular dan lifecycle-oriented.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Struktur master data SATUDATA sudah memiliki hierarchy dan dependency yang saling terintegrasi.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Perubahan mengikuti flow SIMPUL berpotensi mempengaruhi consistency existing database mapping.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Existing backend orchestration SATUDATA sudah menyesuaikan tracking tahapan proyek secara granular.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Penyesuaian sequence SIMPUL berpotensi menambah complexity pada API orchestration dan integration layer.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Existing mekanisme export, timeline management, dan lifecycle tracking SATUDATA sudah mengikuti struktur hierarchy saat ini.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Perubahan flow berisiko meningkatkan technical debt dan effort maintenance existing SATUDATA.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Dari sisi SIMPUL&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Penyesuaian pada SIMPUL relatif lebih memungkinkan karena belum memiliki hierarchy lifecycle sekompleks SATUDATA.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;SIMPUL dapat melakukan concern mapping terhadap hierarchy tahapan SATUDATA.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Penyesuaian orchestration API pada SIMPUL dapat dilakukan untuk mengikuti existing lifecycle SATUDATA.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Pendekatan penyesuaian di sisi SIMPUL lebih minim impact terhadap existing architecture SATUDATA.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="166" width="778" x="-1068" y="424" as="geometry" />
        </mxCell>
        <mxCell id="SpUZeo74qvOX4VSFl6HI-4" edge="1" parent="1" source="SpUZeo74qvOX4VSFl6HI-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="UMBiTt1FIwDFNFkxnXiM-2">
