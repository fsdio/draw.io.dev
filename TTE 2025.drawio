        </UserObject>
        <mxCell id="5C2CKzYaWCP_pC3gi9ix-158" parent="5C2CKzYaWCP_pC3gi9ix-156" style="html=1;rounded=1;absoluteArcSize=1;arcSize=6;verticalAlign=middle;align=center;strokeWidth=2;whiteSpace=wrap;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" value="Client" vertex="1">
