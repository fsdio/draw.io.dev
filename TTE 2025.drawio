        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    logs {\n        char36 id PK\n        timestamp created_at\n        varchar255 nrp\n        integer status_code\n        varchar255 message\n        varchar255 app_id\n        uuid file_id\n    }\n\n    skck_documents {\n        uuid document_id PK\n        text key PK\n        text value\n    }\n\n    file_signatures {\n        uuid id PK\n        uuid file_id\n        varchar255 user_id\n        varchar255 signature_name\n        text signed_file\n        boolean bsre_signed\n        varchar type_signed\n        bigint size\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    files {\n        uuid id PK\n        uuid folder_id\n        varchar255 user_id\n        varchar255 user_name\n        text name\n        varchar visibility\n        text file\n        bigint size\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    signing_status_aggregate {\n        uuid id PK\n        date date\n        varchar status\n        integer total\n    }\n\n    signing_message_aggregate {\n        uuid id PK\n        date date\n        varchar message\n        integer total\n    }&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="cU5TCm0ruV9yWfOMrVZp-122">
