        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    logs {\n        char36 id PK\n        timestamp created_at\n        varchar255 nrp\n        integer status_code\n        varchar255 message\n        varchar255 app_id\n        uuid file_id\n    }\n\n    tte_totp {\n        uuid id PK\n        varchar512 totp\n        timestamp expires_at\n        varchar255 subscriber_id\n        varchar64 otp_hash\n        varchar32 salt\n        varchar36 request_id\n    }\n\n    rate_limiter {\n        varchar36 subscriber_id PK\n        bigint last_epoch_ms\n        timestamp updated_at\n    }\n\n    signing_status_aggregate {\n        uuid id PK\n        date date\n        varchar status\n        integer total\n    }\n\n    signing_message_aggregate {\n        uuid id PK\n        date date\n        varchar message\n        integer total\n    }\n\n    file_signatures {\n        uuid id PK\n        uuid file_id\n        varchar255 user_id\n        varchar255 signature_name\n        text signed_file\n        boolean bsre_signed\n        varchar type_signed\n        bigint size\n        timestamp created_at\n        timestamp updated_at\n    }\n\n    files {\n        uuid id PK\n        uuid folder_id\n        varchar255 user_id\n        varchar255 user_name\n        text name\n        varchar visibility\n        text file\n        bigint size\n        timestamp created_at\n        timestamp updated_at\n    }&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="5C2CKzYaWCP_pC3gi9ix-191">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
