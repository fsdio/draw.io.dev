        <mxCell id="5C2CKzYaWCP_pC3gi9ix-155" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 38px;&quot;&gt;Seal Flow&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="950" x="5290" y="-30" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant Client\n    participant Signer as tte-signer-service\n    participant 3scale as 3scale API\n    participant BSRE as BSRE eSign API\n    participant DB as PostgreSQL\n\n    Note over Client,Signer: === TOTP Activation ===\n    Client-&gt;&gt;Signer: POST /seal/get/activation + app_key\n    Signer-&gt;&gt;3scale: Verify app_key\n    3scale--&gt;&gt;Signer: OK\n    Signer-&gt;&gt;DB: Check rate_limiter (subscriber_id)\n    DB--&gt;&gt;Signer: OK\n    Signer-&gt;&gt;Signer: Generate OTP + salt + hash\n    Signer-&gt;&gt;DB: INSERT tte_totp (subscriber_id, hash, salt, ...)\n    Signer--&gt;&gt;Client: { totpId }\n\n    Note over Client,Signer: === Seal PDF ===\n    Client-&gt;&gt;Signer: POST /seal/pdf + JWT + {totpId, totpCode}\n    Signer-&gt;&gt;3scale: Verify app_key\n    3scale--&gt;&gt;Signer: OK\n    Signer-&gt;&gt;DB: SELECT tte_totp WHERE subscriber_id\n    DB--&gt;&gt;Signer: OTP record\n    Signer-&gt;&gt;Signer: SHA-256(totpCode + salt) == otp_hash?\n    Signer-&gt;&gt;BSRE: POST /seal/pdf\n    BSRE--&gt;&gt;Signer: Seal result\n    Signer-&gt;&gt;DB: DELETE tte_totp (used)\n    Signer-&gt;&gt;DB: INSERT INTO logs\n    Signer--&gt;&gt;Client: Response&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="5C2CKzYaWCP_pC3gi9ix-156">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=1;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="Client" mermaidId="n:Client" mermaidBaseStyle="html=1;shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;edgeStyle&quot;:&quot;elbowEdgeStyle&quot;,&quot;elbow&quot;:&quot;vertical&quot;,&quot;curved&quot;:0,&quot;rounded&quot;:0};lifelineDashed=0;strokeWidth=2;rounded=1;absoluteArcSize=1;arcSize=6;lifelineColor=light-dark(#9370DB,#cccccc);size=65;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="Client" id="5C2CKzYaWCP_pC3gi9ix-157">
          <mxCell parent="5C2CKzYaWCP_pC3gi9ix-156" style="html=1;shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;edgeStyle&quot;:&quot;elbowEdgeStyle&quot;,&quot;elbow&quot;:&quot;vertical&quot;,&quot;curved&quot;:0,&quot;rounded&quot;:0};lifelineDashed=0;strokeWidth=2;rounded=1;absoluteArcSize=1;arcSize=6;lifelineColor=light-dark(#9370DB,#cccccc);size=65;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" vertex="1">
            <mxGeometry height="1158" width="150" x="5530" y="80" as="geometry" />
