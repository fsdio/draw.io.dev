        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cU5TCm0ruV9yWfOMrVZp-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 38px;&quot;&gt;Sign Document (POST /sign)&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="950" x="40" y="40" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    A[Client] --&gt;|POST /sign + JWT + SignDto| B[MainController.sign]\n    B --&gt;|Extract JWT| C{Valid Token?}\n    C --&gt;|No| D[401 Unauthorized]\n    C --&gt;|Yes| E[Get userId, userRole from claims]\n    E --&gt; F[nomor = signDto.getNrp() ?? getNik() ?? -]\n    F --&gt; G[Download PDF from Ceph]\n    G --&gt; H{Download OK?}\n    H --&gt;|No| I[Log error + return 500]\n    H --&gt;|Yes| J[Call AuthService: /users/{userId}]\n    J --&gt; K{User found?}\n    K --&gt;|No| L[Log errorStamp + return 500]\n    K --&gt;|Yes| M[Generate signature image + Stamp PDF]\n    M --&gt; N{bsre=true &amp;&amp;\\n(email\\|nik) &amp;&amp; passphrase?}\n    N --&gt;|No: Stamp only| O[Return stamped PDF + log successStamp]\n    N --&gt;|Yes: Sign with BSRE| P[Call BSRE API: POST /sign/pdf]\n    P --&gt; Q{BSRE success?}\n    Q --&gt;|No| R[Return BSRE error]\n    Q --&gt;|Yes| S[Upload signed PDF to Ceph]\n    S --&gt; T[Create file signature record]\n    T --&gt; U{link provided in body?}\n    U --&gt;|Ya| V[Insert ke skck_documents:\\ndocument_id=fileId, key=link, value=link]\n    U --&gt;|Tidak| W[Skip]\n    V --&gt; X[Post user usage]\n    X --&gt; Y[3scale: get application → account → org]\n    Y --&gt; Z[Post org usage]\n    Z --&gt; AA[Return FileSignatureResponse]\n\n    style D fill:#f88\n    style I fill:#f88\n    style L fill:#f88\n    style R fill:#f88\n    style O fill:#8f8\n    style AA fill:#8f8&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="cU5TCm0ruV9yWfOMrVZp-2">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
