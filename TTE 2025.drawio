        <mxCell id="5C2CKzYaWCP_pC3gi9ix-114" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 38px;&quot;&gt;Sign Flow&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="950" x="3670" y="-50" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant Client\n    participant Signer as tte-signer-service\n    participant Ceph as Ceph Object Storage\n    participant Auth as Auth Service\n    participant BSRE as BSRE eSign API\n    participant 3scale as 3scale API\n    participant DB as PostgreSQL\n\n    Client-&gt;&gt;Signer: POST /sign + JWT + SignDto\n    Signer-&gt;&gt;Signer: Validate JWT → userId, userRole\n    Signer-&gt;&gt;Ceph: download(filename)\n    Ceph--&gt;&gt;Signer: PDF bytes\n\n    Signer-&gt;&gt;Auth: GET /users/{userId}\n    Auth--&gt;&gt;Signer: User{nrp, nik, name, pangkat}\n\n    Signer-&gt;&gt;Signer: Generate signature PNG + Stamp PDF\n\n    alt bsre=true\n        Signer-&gt;&gt;BSRE: POST /sign/pdf {nik/email, passphrase, file, ...}\n        BSRE--&gt;&gt;Signer: Signed PDF\n        Signer-&gt;&gt;Ceph: upload(signedFile)\n        Signer-&gt;&gt;Signer: createFileSignature()\n        Signer-&gt;&gt;Auth: POST /user-usage\n        Signer-&gt;&gt;3scale: GET application → account → org\n        3scale--&gt;&gt;Signer: Account + Org info\n        Signer-&gt;&gt;Auth: POST /org-usage\n        Signer--&gt;&gt;Client: FileSignatureResponse\n    else stamp-only\n        Signer--&gt;&gt;Client: Stamped PDF\n    end\n\n    Signer-&gt;&gt;DB: INSERT INTO logs (nrp, status, ...)&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="5C2CKzYaWCP_pC3gi9ix-115">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
