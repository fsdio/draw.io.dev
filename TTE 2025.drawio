        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="oxO0nA2w7B4sgQM_cRiw-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 38px;&quot;&gt;Sign Document (POST /sign)&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="950" x="40" y="50" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    A[Client] --&gt;|POST /sign + JWT + SignDto| B[MainController.index]\n    B --&gt;|Extract JWT| C{Valid Token?}\n    C --&gt;|No| D[401 Unauthorized]\n    C --&gt;|Yes| E[Get userId, userRole from claims]\n    E --&gt; F[nomor = signDto.getNik()]\n    F --&gt; G[Download PDF from Ceph]\n    G --&gt; H{Download OK?}\n    H --&gt;|No| I[Log error + return 500]\n    H --&gt;|Yes| J[Call AuthService: /users/{userId}]\n    J --&gt; K{User found?}\n    K --&gt;|No| L[Log errorStamp + return 500]\n    K --&gt;|Yes| M[Generate EPPNS stamp:\\nQR code + disclaimer only]\n    M --&gt; N[Stamp PDF]\n    N --&gt; O{bsre=true &amp;&amp;\\n(email\\|nik) &amp;&amp; passphrase?}\n    O --&gt;|No: Stamp only| P[Return stamped PDF + log successStamp]\n    O --&gt;|Yes: Sign with BSRE| Q[Call BSRE API: POST /sign/pdf]\n    Q --&gt; R{BSRE success?}\n    R --&gt;|No| S[Return BSRE error]\n    R --&gt;|Yes| T[Upload signed PDF to Ceph]\n    T --&gt; U[Create file signature record]\n    U --&gt; V[Post user usage]\n    V --&gt; W[3scale: get application → account → org]\n    W --&gt; X[Post org usage]\n    X --&gt; Y[Return FileSignatureResponse]\n\n    style D fill:#f88\n    style I fill:#f88\n    style L fill:#f88\n    style S fill:#f88\n    style P fill:#8f8\n    style Y fill:#8f8&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="u6Wky_xYcnymz8orIPcR-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
