        <mxCell id="cU5TCm0ruV9yWfOMrVZp-77" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 38px;&quot;&gt;Sign Flow&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="950" x="2570" y="30" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant Client\n    participant SKCK as tte-signer-skck-service\n    participant Ceph as Ceph Object Storage\n    participant Auth as Auth Service\n    participant BSRE as BSRE eSign API\n    participant 3scale as 3scale API\n    participant DB as PostgreSQL\n\n    Client-&gt;&gt;SKCK: POST /sign + JWT + SignDto{nrp, nik, fileId, link}\n    SKCK-&gt;&gt;SKCK: Validate JWT → userId, userRole\n    SKCK-&gt;&gt;Ceph: download(filename)\n    Ceph--&gt;&gt;SKCK: PDF bytes\n\n    SKCK-&gt;&gt;Auth: GET /users/{userId}\n    Auth--&gt;&gt;SKCK: UserFindData{nrp, nik, name, ...}\n\n    SKCK-&gt;&gt;SKCK: generate() → signature stamp + PDF\n\n    alt bsre=true\n        SKCK-&gt;&gt;BSRE: POST /sign/pdf {nik/email, passphrase, file, ...}\n        BSRE--&gt;&gt;SKCK: Signed PDF\n        SKCK-&gt;&gt;Ceph: upload(signedFile)\n        SKCK-&gt;&gt;SKCK: createFileSignature()\n\n        alt link exist\n            SKCK-&gt;&gt;DB: INSERT skck_documents (fileId, \&quot;link\&quot;, value)\n        end\n\n        SKCK-&gt;&gt;Auth: POST /user-usage\n        SKCK-&gt;&gt;3scale: GET application → account → org\n        3scale--&gt;&gt;SKCK: Account + Org\n        SKCK-&gt;&gt;Auth: POST /org-usage\n        SKCK--&gt;&gt;Client: FileSignatureResponse\n    else stamp-only\n        SKCK--&gt;&gt;Client: Stamped PDF\n    end\n\n    SKCK-&gt;&gt;DB: INSERT INTO logs (nrp, app_id, status_code, ...)&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="cU5TCm0ruV9yWfOMrVZp-78">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
