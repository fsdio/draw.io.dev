        <mxCell id="cU5TCm0ruV9yWfOMrVZp-121" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-size: 38px;&quot;&gt;Basis Data&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="950" x="4400" y="40" as="geometry" />
